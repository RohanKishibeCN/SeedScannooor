# ═══════════════════════════════════════════
# SeedScannooor 配置
# ═══════════════════════════════════════════

# ── 基础 API 密钥 ──
ETHERSCAN_API_KEY=YourApiKeyToken
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxxxx
NOTION_API_KEY=ntn_xxxxx
NOTION_DATABASE_ID=35808fc26c7380daba6fcfcd7fdccc0f

# ── 链开关 ──
# 哪些链参与扫描。1=启用，0=禁用（或直接注释掉）
CHAIN_ETHEREUM=1
CHAIN_SOLANA=1
# CHAIN_BSC=1
# CHAIN_POLYGON=1
# CHAIN_ARBITRUM=1
# CHAIN_BASE=1

# ── 扫描参数 ──
# 每条助记词派生的地址数量
SCAN_DEPTH=5
# USD 阈值，只有总估值 >= 此值才写入 Notion
THRESHOLD_USD=5.0

# ── Etherscan 查询参数 ──
# 调用间隔（毫秒），免费版上限 3 calls/sec，推荐 350ms
ETHERSCAN_INTERVAL_MS=350

# ETH 上的 ERC20 代币合约（需要查询余额的代币）
# 格式: SYMBOL=CONTRACT_ADDRESS,SYMBOL=CONTRACT_ADDRESS
ETH_TOKENS=USDT=0xdAC17F958D2ee523a2206206994597C13D831ec7,USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# ── Solana 查询参数 ──
# Solana RPC 并发上限
MAX_CONCURRENT=1
# Solana 请求间隔（毫秒）
SCAN_INTERVAL_MS=3000

# Solana SPL Token Mint 地址
# 格式: SYMBOL=MINT_ADDRESS,SYMBOL=MINT_ADDRESS
SOL_TOKENS=USDT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB,USDC=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDg1v

# ── USD 价格查询 ──
# 可选，从 CoinGecko 获取实时 USD 价格（不填也能用，有限流风险）
# COINGECKO_API_KEY=
