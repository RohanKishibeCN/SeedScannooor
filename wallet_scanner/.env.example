# EVM RPC URLs (Alchemy)
ALCHEMY_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_BSC_RPC_URL=https://bsc-rpc.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_POLYGON_RPC_URL=https://polygon-rpc.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_BASE_RPC_URL=https://base-rpc.g.alchemy.com/v2/YOUR_KEY_HERE

# Solana RPC (Helius)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Notion
NOTION_API_KEY=secret_YOUR_KEY_HERE
NOTION_DATABASE_ID=YOUR_DATABASE_ID_HERE

# 扫描参数（可选，不填则使用默认值）
# 每条助记词派生的地址数量（EVM 和 Solana 统一）
SCAN_DEPTH=20
# 余额阈值（USD），只有总估值 >= 此值才写入 Notion
THRESHOLD_USD=10.0
