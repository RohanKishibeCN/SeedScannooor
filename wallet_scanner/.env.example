# Tatum API Key（EVM 聚合余额 API）
TATUM_API_KEY=YOUR_TATUM_API_KEY_HERE

# Helius RPC URL（Solana RPC）
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Notion
NOTION_API_KEY=secret_YOUR_KEY_HERE
NOTION_DATABASE_ID=YOUR_DATABASE_ID_HERE

# 扫描参数（可选，不填则使用默认值）
# 每条助记词派生的地址数量（EVM 和 Solana 统一）
SCAN_DEPTH=10
# 余额阈值（USD），只有总估值 >= 此值才写入 Notion
THRESHOLD_USD=10.0
#
# 并发/限流（可选）
# MAX_CONCURRENT=10
# SCAN_INTERVAL_MS=100

# 链开关（默认只扫描 ethereum 和 solana）
# 设置为 1/true/yes/on 启用对应链
CHAIN_ETHEREUM=1
CHAIN_SOLANA=1
# CHAIN_BSC=1
# CHAIN_POLYGON=1
# CHAIN_ARBITRUM=1
# CHAIN_BASE=1
